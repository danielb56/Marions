# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me

# Cloudflare R2 (private bucket, S3 API credentials)
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET=marion-work-orders

# Transactional notifications
RESEND_API_KEY=re_replace_me
RESEND_FROM=REME Painting Group <work@your-domain.com.au>
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM=+61replace_me

# Scheduled notification dispatcher
CRON_SECRET=replace_with_at_least_32_random_characters

# Optional monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
